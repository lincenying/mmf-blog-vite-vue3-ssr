{
  "name": "mmf-blog-vite-vue3-ssr",
  "type": "module",
  "version": "1.25.1029",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "author": "lincenying <lincenying@qq.com>",
  "engines": {
    "node": ">=16.13.0"
  },
  "scripts": {
    "serve": "nodemon --watch ./server.dev.ts --exec tsx ./server.dev.ts",
    "build": "tsx polyfill.ts && npm run build:client && npm run build:server && npm run build:server:entry",
    "build:client": "vite build --ssrManifest --outDir dist/client",
    "build:server": "cross-env VITE_APP_SSR=true vite build --ssr src/entry-server.ts --outDir dist/server",
    "build:server:entry": "tsup --entry.server server.prod.ts --format esm --target es2020",
    "start": "cross-env NODE_ENV=production node ./dist/server.js",
    "generate": "vite build --ssrManifest --outDir dist/static && npm run build:server && tsx ./prerender.ts",
    "workbox": "workbox generateSW workbox-config.js",
    "lint": "eslint .",
    "lint:ts": "vue-tsc -b --noEmit",
    "lint:fix": "eslint . --fix",
    "lint:css": "stylelint '**/*.{css,scss}' --fix --allow-empty-input",
    "release": "bumpp",
    "prepare[-del]": "npx simple-git-hooks",
    "lint-staged": "lint-staged"
  },
  "dependencies": {
    "@kangc/v-md-editor": "catalog:prod",
    "@lincy/utils": "catalog:prod",
    "@unhead/ssr": "catalog:prod",
    "@unhead/vue": "catalog:prod",
    "@vue/server-renderer": "catalog:prod",
    "@vueuse/core": "catalog:prod",
    "axios": "catalog:prod",
    "compression": "catalog:node",
    "cookie-parser": "catalog:node",
    "element-plus": "catalog:prod",
    "express": "catalog:node",
    "http-proxy-middleware": "catalog:node",
    "js-cookie": "catalog:prod",
    "lodash": "catalog:prod",
    "lru-cache": "catalog:node",
    "md5": "catalog:prod",
    "morgan": "catalog:node",
    "pinia": "catalog:prod",
    "prismjs": "catalog:prod",
    "qs": "catalog:prod",
    "request-ip": "catalog:node",
    "serve-static": "catalog:node",
    "store2": "catalog:prod",
    "vue": "catalog:prod",
    "vue-content-loader": "catalog:prod",
    "vue-loading-overlay": "catalog:prod",
    "vue-router": "catalog:prod"
  },
  "devDependencies": {
    "@iconify-json/mdi": "catalog:icons",
    "@lincy/eslint-config": "catalog:lint",
    "@lincy/stylelint-config": "catalog:lint",
    "@lincy/unocss-base-config": "catalog:dev",
    "@types/compression": "catalog:types",
    "@types/cookie-parser": "catalog:types",
    "@types/express": "catalog:types",
    "@types/js-cookie": "catalog:types",
    "@types/lodash": "catalog:types",
    "@types/md5": "catalog:types",
    "@types/morgan": "catalog:types",
    "@types/polyfill-library": "catalog:types",
    "@types/prismjs": "catalog:types",
    "@types/request-ip": "catalog:types",
    "@types/serve-static": "catalog:types",
    "@unocss/eslint-plugin": "catalog:lint",
    "@vitejs/plugin-vue": "catalog:dev",
    "@vitejs/plugin-vue-jsx": "catalog:dev",
    "@vue/compiler-sfc": "catalog:dev",
    "bumpp": "catalog:dev",
    "cross-env": "catalog:dev",
    "eslint": "catalog:lint",
    "eslint-plugin-format": "catalog:lint",
    "express-rate-limit": "catalog:dev",
    "lint-staged": "catalog:dev",
    "mockjs": "catalog:dev",
    "nodemon": "catalog:dev",
    "polyfill-library": "catalog:dev",
    "postcss": "catalog:dev",
    "sass": "catalog:dev",
    "simple-git-hooks": "catalog:dev",
    "stylelint": "catalog:lint",
    "tsup": "catalog:dev",
    "tsx": "catalog:dev",
    "typescript": "catalog:dev",
    "unocss": "catalog:dev",
    "unplugin-auto-import": "catalog:dev",
    "unplugin-vue-components": "catalog:dev",
    "unplugin-vue-macros": "catalog:dev",
    "vite": "catalog:dev",
    "vite-plugin-mock": "catalog:dev",
    "vite-plugin-pwa": "catalog:dev",
    "vue-tsc": "catalog:dev"
  },
  "simple-git-hooks[-del]": {
    "pre-commit": "npm run lint-staged"
  },
  "lint-staged[-del]": {
    "*.{[jt]s?(x),vue,md}": "eslint --fix",
    "*.{css,scss}": "stylelint --fix --allow-empty-input"
  }
}
